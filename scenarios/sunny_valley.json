{
  "id": "sunny_valley",
  "name": "Sunny Valley to City",
  "description": "A solar and wind-rich western valley feeds an eastern city through a constrained transmission corridor. Learn how congestion creates price separation, why the solar node can be cheap while the city stays expensive, and what happens when you upgrade the line.",

  "nodes": [
    { "id": "N1", "name": "SunnyValley", "x": -4, "y": -2, "zone_id": "WEST" },
    { "id": "N2", "name": "WindRidge",   "x": -4, "y":  2, "zone_id": "WEST" },
    { "id": "N3", "name": "HubPoint",    "x":  0, "y":  0, "zone_id": "CENTRAL" },
    { "id": "N4", "name": "EastCity",    "x":  4, "y": -2, "zone_id": "EAST" },
